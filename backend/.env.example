# Copy this file to .env and fill in real values. Never commit the real .env file.

# Bootstrap/master admin login (works even if the database/user store is empty).
ADMIN_USER=change-me
ADMIN_PASS=change-me

# Used to sign login tokens. Generate with: openssl rand -hex 32
SECRET_KEY=change-me

# Comma-separated list of frontend origins allowed to call this API.
# Example: https://taxautomationapp.onrender.com,http://localhost:3000
ALLOWED_ORIGINS=

# Postgres connection string (see Phase 1 of the modernization plan).
# Example (Neon): postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=
